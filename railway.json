{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "services": [
    {
      "name": "frontend",
      "rootDirectory": "frontend",
      "sourceDirectory": "frontend",
      "deploy": {
        "startCommand": "node server.js"
      }
    },
    {
      "name": "backend",
      "rootDirectory": "backend",
      "sourceDirectory": "backend",
      "deploy": {
        "startCommand": "node index.js"
      }
    }
  ]
}